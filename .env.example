# Resend transactional email — required for the /api/contact route.
# Get a key from https://resend.com/api-keys
RESEND_API_KEY=

# Where inquiries are delivered.
# Defaults to siteConfig.contact.email (sixrowbrewing@gmail.com).
CONTACT_TO_EMAIL=sixrowbrewing@gmail.com

# The "From" address Resend sends as.
# Until you verify a domain in Resend, you MUST use onboarding@resend.dev
# (which can only deliver to the email used to sign up the Resend account).
# After verifying sixrowbrewing.com in Resend, switch to e.g. inquiries@sixrowbrewing.com.
CONTACT_FROM_EMAIL="SRBC Website <onboarding@resend.dev>"
